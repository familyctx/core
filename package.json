{
  "name": "@familyctx/core",
  "version": "0.1.0",
  "description": "Context-based identity layer for multi-profile applications.",
  "license": "MIT",
  "author": "Preston Arnold <prestonarnold.uk>",
  "repository": {
    "type": "git",
    "url": "https://github.com/familyctx/core"
  },
  "keywords": [
    "auth",
    "identity",
    "context",
    "session",
    "profile",
    "sdk"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.27.0"
}
